generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  CAPTAIN
  CASHIER
  VIEWER
}


enum TableStatus {
  AVAILABLE
  OCCUPIED
  WAITING_BILL
  RESERVED
}

enum TableSessionStatus {
  OPEN
  WAITING_BILL
  CLOSED
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  DELIVERED
  WAITING_BILL
  PAID
  CANCELLED
}

enum PaymentProvider {
  CASH
  PAYMOB
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  ORDER_CREATED
  ORDER_UPDATED
  WAITER_CALLED
  BILL_REQUESTED
  PAYMENT_UPDATED
  RESERVATION_CREATED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

enum ThemePurchaseStatus {
  PENDING
  ACTIVE
}

model Plan {
  id            String         @id @default(cuid())
  slug          String         @unique
  nameAr        String
  nameEn        String
  priceMonthly  Float
  maxBranches   Int
  maxProducts   Int
  maxUsers      Int
  customDomain  Boolean        @default(false)
  hasTables     Boolean        @default(false)
  hasOrdering   Boolean        @default(false)
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id                 String             @id @default(cuid())
  restaurantId       String             @unique
  restaurant         Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime?
  paymentReference   String?
  paymentNotes       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([planId])
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Restaurant {
  id            String        @id @default(cuid())
  nameAr        String
  nameEn        String
  descriptionAr String?
  descriptionEn String?
  logo          String?
  coverImage    String?
  slug          String        @unique
  subdomain     String?       @unique
  customDomain  String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  branches      Branch[]
  users         User[]
  categories    Category[]
  products      Product[]
  addons        Addon[]
  sizes         Size[]
  offers        Offer[]
  galleries     Gallery[]
  media         Media[]
  diningTables  DiningTable[]
  floors        Floor[]
  tableSessions TableSession[]
  orders        Order[]
  payments      Payment[]
  reservations  Reservation[]
  notifications Notification[]
  settings       Settings?
  subscription   Subscription?
  themePurchases ThemePurchase[]
}

model Branch {
  id              String          @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  nameAr          String
  nameEn          String
  addressAr       String?
  addressEn       String?
  latitude        Float?
  longitude       Float?
  whatsapp        String?
  phone           String?
  instagram       String?
  facebook        String?
  googleMaps      String?
  googleReviewUrl String?
  reservationPhone String?
  hoursAr         String?
  hoursEn         String?
  workingHours    Json?
  coverImage      String?
  logo            String?
  primaryColor    String          @default("#1a1a2e")
  secondaryColor  String          @default("#e94560")
  slug            String          @unique
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  qrCodes         QRCode[]
  diningTables    DiningTable[]
  floors          Floor[]
  tableSessions   TableSession[]
  orders          Order[]
  payments        Payment[]
  reservations    Reservation[]
  notifications   Notification[]
  productBranches ProductBranch[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([restaurantId])
}

model DiningTable {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name         String
  number       Int
  seats        Int?
  status       TableStatus  @default(AVAILABLE)
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  floorItems   FloorTable[]
  sessions     TableSession[]
  reservations Reservation[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([branchId, number])
  @@index([restaurantId])
  @@index([branchId])
  @@index([status])
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  nameAr       String
  nameEn       String
  image        String?
  sortOrder    Int        @default(0)
  isVisible    Boolean    @default(true)
  products     Product[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model Product {
  id              String          @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nameAr          String
  nameEn          String
  descriptionAr   String?
  descriptionEn   String?
  image           String?
  price           Float
  compareAtPrice  Float?
  tax             Float           @default(0)
  isAvailable     Boolean         @default(true)
  sortOrder       Int             @default(0)
  isBestSeller    Boolean         @default(false)
  isNew           Boolean         @default(false)
  isOffer         Boolean         @default(false)
  isSpicy         Boolean         @default(false)
  isVegetarian    Boolean         @default(false)
  isVegan         Boolean         @default(false)
  isHot           Boolean         @default(false)
  isCold          Boolean         @default(false)
  calories        Int?
  ingredientsAr   String?
  ingredientsEn   String?
  allergensAr     String?
  allergensEn     String?
  temperature     String?
  prepTime        Int?
  spiceLevel      Int?
  images          ProductImage[]
  productSizes    ProductSize[]
  productAddons   ProductAddon[]
  productBranches ProductBranch[]
  orderItems      OrderItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductBranch {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isAvailable Boolean @default(true)

  @@unique([productId, branchId])
}

model Addon {
  id           String         @id @default(cuid())
  restaurantId String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  nameAr       String
  nameEn       String
  price        Float          @default(0)
  isActive     Boolean        @default(true)
  sortOrder    Int            @default(0)
  productAddons ProductAddon[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([restaurantId])
}

model ProductAddon {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addonId   String
  addon     Addon   @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([productId, addonId])
}

model Size {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  nameAr       String
  nameEn       String
  priceModifier Float        @default(0)
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  productSizes ProductSize[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([restaurantId])
}

model ProductSize {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizeId    String
  size      Size    @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  price     Float?

  @@unique([productId, sizeId])
}

model Offer {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  titleAr      String
  titleEn      String
  descriptionAr String?
  descriptionEn String?
  image        String?
  discount     Float?
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model QRCode {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  color     String   @default("#000000")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         UserRole   @default(VIEWER)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  isActive     Boolean    @default(true)
  pushSubscriptions PushSubscription[]
  notifications Notification[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model MenuTheme {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameAr        String
  nameEn        String
  descriptionAr String
  descriptionEn String
  isPremium     Boolean  @default(false)
  price         Float    @default(0)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ThemePurchase {
  id               String              @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  themeSlug        String
  status           ThemePurchaseStatus @default(PENDING)
  pricePaid        Float
  paymentReference String?
  paymentNotes     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([restaurantId, themeSlug])
  @@index([restaurantId])
}

model Settings {
  id             String     @id @default(cuid())
  restaurantId   String     @unique
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  currency       String     @default("EGP")
  currencySymbol String     @default("ج.م")
  taxRate        Float      @default(15)
  language       String     @default("ar")
  theme                 String     @default("light")
  menuTheme             String     @default("classic")
  fontFamily            String     @default("Inter")
  borderRadius          String     @default("1rem")
  notificationsEnabled  Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Floor {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name         String
  width        Int          @default(1200)
  height       Int          @default(800)
  tables       FloorTable[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([restaurantId])
  @@index([branchId])
}

model FloorTable {
  id        String      @id @default(cuid())
  floorId   String
  floor     Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  tableId   String
  table     DiningTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  shape     String      @default("rectangle")
  x         Float       @default(80)
  y         Float       @default(80)
  width     Float       @default(120)
  height    Float       @default(80)
  rotation  Float       @default(0)
  color     String      @default("#2563eb")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([floorId, tableId])
  @@index([tableId])
}

model TableSession {
  id             String             @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId        String
  table          DiningTable        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  status         TableSessionStatus @default(OPEN)
  guestName      String?
  guestPhone     String?
  guestCount     Int?
  subtotal       Float              @default(0)
  taxTotal       Float              @default(0)
  serviceTotal   Float              @default(0)
  total          Float              @default(0)
  openedAt       DateTime           @default(now())
  billRequestedAt DateTime?
  closedAt       DateTime?
  orders         Order[]
  payments       Payment[]
  notifications  Notification[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([tableId])
  @@index([status])
}

model Order {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sessionId    String
  session      TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status       OrderStatus  @default(NEW)
  customerNote String?
  subtotal     Float
  taxTotal     Float        @default(0)
  total        Float
  items        OrderItem[]
  payments     Payment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([restaurantId])
  @@index([branchId])
  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  nameAr       String
  nameEn       String
  quantity     Int
  unitPrice    Float
  total        Float
  notes        String?
  modifiers    Json?

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                  String          @id @default(cuid())
  restaurantId        String
  restaurant          Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId            String
  branch              Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sessionId           String
  session             TableSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderId             String?
  order               Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  provider            PaymentProvider
  status              PaymentStatus   @default(PENDING)
  amount              Float
  currency            String          @default("EGP")
  providerReference   String?
  providerCheckoutUrl String?
  rawResponse         Json?
  paidAt              DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([restaurantId])
  @@index([branchId])
  @@index([sessionId])
  @@index([orderId])
  @@index([provider, status])
}

model Reservation {
  id             String            @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId        String?
  table          DiningTable?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerName   String
  customerPhone  String
  partySize      Int
  startsAt       DateTime
  notes          String?
  status         ReservationStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([restaurantId])
  @@index([branchId])
  @@index([tableId])
  @@index([startsAt])
  @@index([status])
}

model Notification {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sessionId    String?
  session      TableSession?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type         NotificationType
  title        String
  body         String
  data         Json?
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  @@index([restaurantId])
  @@index([branchId])
  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Gallery {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  titleAr      String?
  titleEn      String?
  image        String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model Media {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  url          String
  type         String     @default("image")
  size         Int?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}
