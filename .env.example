# Local Docker Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qrmenu?schema=public"

# Supabase (production / Vercel) - copy from Dashboard -> Connect
# Runtime (transaction pooler, port 6543)
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations / prisma migrate deploy (session pooler, port 5432)
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"

AUTH_SECRET="change-me-to-a-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="localhost"

# Supabase Storage (image uploads)
